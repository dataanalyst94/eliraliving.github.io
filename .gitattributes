# Normalize line endings to LF for all text so the static-site generator's
# rebuilds don't produce phantom CRLF/LF-only diffs (which caused push conflicts).
* text=auto eol=lf

*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.xml   text eol=lf
*.txt   text eol=lf
*.md    text eol=lf
*.svg   text eol=lf
*.webmanifest text eol=lf

# Binary assets — never touch
*.jpg  binary
*.jpeg binary
*.png  binary
*.gif  binary
*.webp binary
*.ico  binary
*.ttf  binary
*.otf  binary
*.woff  binary
*.woff2 binary
*.pdf  binary
*.mp4  binary
