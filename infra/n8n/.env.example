# Copy to ".env" on the server and fill in. NEVER commit the real .env.
# Subdomain that points (A record) to your Oracle VM's public IP:
DOMAIN=n8n.eliraliving.com

# Your timezone (Finland):
TZ=Europe/Helsinki

# Random 32+ char secret. Generate with:  openssl rand -hex 24
# If you ever lose this, all saved n8n credentials become unreadable — back it up.
N8N_ENCRYPTION_KEY=replace-with-openssl-rand-hex-24
