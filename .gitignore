# Dependencies
node_modules/

# Cloudflare Wrangler
checkout-worker/.wrangler/
.dev.vars
.wrangler/

# Secrets — never commit
*.env
.env*
.secret*
# …but the n8n example template is safe to commit
!infra/n8n/.env.example

# OS / editor
.DS_Store
Thumbs.db
*.log

# Generated marketing drafts (transient)
marketing/pitches/

# Private internal tools — never publish to the public site
kanban.html
elira-board.json

# Product images: commit only the optimized web versions, not the raw originals
assets/img/*
!assets/img/cream.jpg
!assets/img/cleanser.jpg
!assets/img/toner.jpg
!assets/img/shampoo.jpg
!assets/img/serum.jpg
!assets/img/peptide-serum.jpg
!assets/img/peptide-serum.webp
!assets/img/og-image.jpg
!assets/img/cream-hero.webp
!assets/img/cream-hero.png
!assets/img/hero.jpg
!assets/img/hero.webp
# WebP siblings of the deployed product images (generated by tools/optimize-images.js)
!assets/img/cream.webp
!assets/img/cleanser.webp
!assets/img/toner.webp
!assets/img/shampoo.webp
!assets/img/serum.webp
# Responsive variants (generated by tools/responsive-images.js)
!assets/img/*-480.webp
!assets/img/*-480.jpg
!assets/img/*-960.webp
!assets/img/*-960.jpg
# Optimized PDP gallery images (generated by tools/_process-images.js)
!assets/img/gallery/
!assets/img/gallery/*.jpg
!assets/img/gallery/*.webp
# Brand logo, favicons & app icons (generated by tools/gen-brand-assets.js)
!assets/img/brand/
!assets/img/brand/*.png

# Generated social marketing images (kept out of the public site)
marketing/social/
